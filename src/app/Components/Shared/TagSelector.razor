@rendermode InteractiveServer

<div class="relative" @onfocusout="HandleFocusOut" tabindex="-1">
    <label class="block text-sm font-medium text-gray-700 mb-1.5">Tags</label>

    <div class="flex flex-wrap items-center gap-1.5 p-2 min-h-[42px] bg-white border border-gray-300 rounded-lg focus-within:ring-2 focus-within:ring-primary-500 focus-within:border-primary-500 transition-all duration-200 cursor-text"
         @onclick="FocusInput">

        @foreach (var tag in SelectedTags)
        {
            <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium bg-primary-50 text-primary-700 animate-scale-in">
                @tag
                <button type="button" @onclick="() => RemoveTag(tag)" @onclick:stopPropagation="true"
                        class="inline-flex items-center justify-center w-3.5 h-3.5 rounded-full hover:bg-primary-200 transition-colors duration-150">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-2.5 w-2.5" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                    </svg>
                </button>
            </span>
        }

        <input @ref="inputRef"
               type="text"
               @bind="searchText"
               @bind:event="oninput"
               @onkeydown="HandleKeyDown"
               @onfocus="() => showDropdown = true"
               placeholder="@(SelectedTags.Count == 0 ? "Add tags..." : "")"
               class="flex-1 min-w-[120px] border-none outline-none text-sm bg-transparent placeholder-gray-400 p-0.5" />
    </div>

    @if (showDropdown && FilteredSuggestions.Count > 0 || showDropdown && !string.IsNullOrWhiteSpace(searchText))
    {
        <div class="absolute z-50 w-full mt-1 bg-white border border-gray-200 rounded-lg shadow-lg overflow-hidden animate-scale-in">
            <ul class="max-h-48 overflow-y-auto py-1">
                @foreach (var (suggestion, index) in FilteredSuggestions.Select((s, i) => (s, i)))
                {
                    <li>
                        <button type="button"
                                @onclick="() => AddTag(suggestion)"
                                class="@DropdownItemClass(index) w-full text-left px-3 py-2 text-sm transition-colors duration-100">
                            @suggestion
                        </button>
                    </li>
                }
                @if (!string.IsNullOrWhiteSpace(searchText) && !FilteredSuggestions.Contains(searchText.Trim(), StringComparer.OrdinalIgnoreCase))
                {
                    <li>
                        <button type="button"
                                @onclick="() => AddTag(searchText.Trim())"
                                class="w-full text-left px-3 py-2 text-sm text-primary-600 hover:bg-primary-50 transition-colors duration-100">
                            <span class="inline-flex items-center gap-1.5">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
                                </svg>
                                Create "<strong>@searchText.Trim()</strong>"
                            </span>
                        </button>
                    </li>
                }
            </ul>
        </div>
    }

    @foreach (var tag in SelectedTags)
    {
        <input type="hidden" name="@FieldName" value="@tag" />
    }
</div>

@code {
    [Parameter] public List<string> SelectedTags { get; set; } = [];
    [Parameter] public EventCallback<List<string>> SelectedTagsChanged { get; set; }
    [Parameter] public List<string> AvailableTags { get; set; } = [];
    [Parameter] public string FieldName { get; set; } = "Tags";

    private string searchText = "";
    private bool showDropdown;
    private int highlightedIndex = -1;
    private ElementReference inputRef;

    private List<string> FilteredSuggestions =>
        AvailableTags
            .Where(t => !SelectedTags.Contains(t, StringComparer.OrdinalIgnoreCase))
            .Where(t => string.IsNullOrWhiteSpace(searchText) || t.Contains(searchText.Trim(), StringComparison.OrdinalIgnoreCase))
            .OrderBy(t => t)
            .Take(10)
            .ToList();

    private string DropdownItemClass(int index) =>
        index == highlightedIndex
            ? "bg-primary-50 text-primary-700"
            : "text-gray-700 hover:bg-gray-50";

    private async Task AddTag(string tag)
    {
        tag = tag.Trim();
        if (string.IsNullOrWhiteSpace(tag) || SelectedTags.Contains(tag, StringComparer.OrdinalIgnoreCase))
            return;

        SelectedTags.Add(tag);
        if (!AvailableTags.Contains(tag, StringComparer.OrdinalIgnoreCase))
            AvailableTags.Add(tag);

        searchText = "";
        highlightedIndex = -1;
        await SelectedTagsChanged.InvokeAsync(SelectedTags);
    }

    private async Task RemoveTag(string tag)
    {
        SelectedTags.Remove(tag);
        await SelectedTagsChanged.InvokeAsync(SelectedTags);
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "Enter":
                if (highlightedIndex >= 0 && highlightedIndex < FilteredSuggestions.Count)
                    await AddTag(FilteredSuggestions[highlightedIndex]);
                else if (!string.IsNullOrWhiteSpace(searchText))
                    await AddTag(searchText.Trim());
                break;
            case "Backspace" when string.IsNullOrEmpty(searchText) && SelectedTags.Count > 0:
                await RemoveTag(SelectedTags[^1]);
                break;
            case "ArrowDown":
                highlightedIndex = Math.Min(highlightedIndex + 1, FilteredSuggestions.Count - 1);
                break;
            case "ArrowUp":
                highlightedIndex = Math.Max(highlightedIndex - 1, 0);
                break;
            case "Escape":
                showDropdown = false;
                highlightedIndex = -1;
                break;
        }
    }

    private void HandleFocusOut()
    {
        _ = Task.Delay(200).ContinueWith(_ => InvokeAsync(() =>
        {
            showDropdown = false;
            highlightedIndex = -1;
            StateHasChanged();
        }));
    }

    private async Task FocusInput()
    {
        await inputRef.FocusAsync();
    }
}
