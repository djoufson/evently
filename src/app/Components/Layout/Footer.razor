<footer class="bg-white border-t border-gray-200 mt-auto">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="py-12 grid grid-cols-1 md:grid-cols-4 gap-8">
            <div class="md:col-span-2">
                <a href="" class="text-xl font-bold text-primary-600 tracking-tight">Evently</a>
                <p class="mt-3 text-sm text-gray-500 max-w-md leading-relaxed">
                    The smart event management platform. Create, discover, and manage events with AI-powered recommendations and beautiful design.
                </p>
            </div>

            <div>
                <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Platform</h3>
                <ul class="mt-4 space-y-3">
                    <li><a href="/" class="text-sm text-gray-600 hover:text-primary-600 transition-colors duration-200">Browse Events</a></li>
                    <li><a href="/events/create" class="text-sm text-gray-600 hover:text-primary-600 transition-colors duration-200">Create Event</a></li>
                </ul>
            </div>

            <div>
                <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Project</h3>
                <ul class="mt-4 space-y-3">
                    <li><span class="text-sm text-gray-600">Built with .NET & Blazor SSR</span></li>
                    <li><span class="text-sm text-gray-600">Tailwind CSS v4</span></li>
                    <li><span class="text-sm text-gray-600">Semantic Kernel</span></li>
                </ul>
            </div>
        </div>

        <div class="border-t border-gray-100 py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
            <p class="text-xs text-gray-400">
                @DateTime.Now.Year Evently. Open source demo project.
            </p>
            <div class="flex items-center gap-1 text-xs text-gray-400">
                <span>Crafted with</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd" />
                </svg>
                <span>and AI</span>
            </div>
        </div>
    </div>
</footer>
