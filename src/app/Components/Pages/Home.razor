@page "/"
@using app.Models
@using app.Services
@inject IEventService EventService

<PageTitle>Evently - Discover Events</PageTitle>

<!-- Hero Section -->
<section class="relative overflow-hidden bg-gradient-to-br from-primary-950 via-primary-900 to-primary-800">
    <div class="absolute inset-0 overflow-hidden">
        <div class="absolute -top-1/2 -right-1/4 w-[800px] h-[800px] rounded-full bg-primary-700/20 blur-3xl"></div>
        <div class="absolute -bottom-1/2 -left-1/4 w-[600px] h-[600px] rounded-full bg-primary-600/10 blur-3xl"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 sm:py-32">
        <div class="max-w-2xl animate-fade-in">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/10 backdrop-blur-sm border border-white/10 text-primary-200 text-xs font-medium mb-6">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
                AI-powered event management
            </div>
            <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white tracking-tight leading-[1.1]">
                Discover events that
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-300 to-primary-100">inspire you</span>
            </h1>
            <p class="mt-6 text-lg text-primary-200/80 leading-relaxed max-w-lg">
                Create, manage, and explore events with a beautiful interface. Enhanced with AI for smart recommendations and content generation.
            </p>
            <div class="mt-8 flex flex-wrap items-center gap-4">
                <a href="/events/create"
                   class="inline-flex items-center gap-2 bg-white text-primary-900 hover:bg-primary-50 px-6 py-3 rounded-xl text-sm font-semibold transition-all duration-300 hover:shadow-lg hover:shadow-white/20 hover:-translate-y-0.5">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
                    </svg>
                    Create Event
                </a>
                <a href="#events"
                   class="inline-flex items-center gap-2 text-primary-200 hover:text-white px-6 py-3 rounded-xl text-sm font-medium transition-all duration-200">
                    Browse events
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                    </svg>
                </a>
            </div>
        </div>

        <!-- Stats -->
        @if (events.Count > 0)
        {
            <div class="mt-16 grid grid-cols-3 gap-8 max-w-lg animate-slide-up" style="animation-delay: 200ms">
                <div>
                    <div class="text-3xl font-bold text-white">@events.Count</div>
                    <div class="mt-1 text-sm text-primary-300">Events</div>
                </div>
                <div>
                    <div class="text-3xl font-bold text-white">@totalTags</div>
                    <div class="mt-1 text-sm text-primary-300">Tags</div>
                </div>
                <div>
                    <div class="text-3xl font-bold text-white">@upcomingCount</div>
                    <div class="mt-1 text-sm text-primary-300">Upcoming</div>
                </div>
            </div>
        }
    </div>
</section>

<!-- Features Strip -->
<section class="bg-white border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 sm:gap-8">
            <div class="flex items-start gap-3">
                <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-primary-50 flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                    </svg>
                </div>
                <div>
                    <h3 class="text-sm font-semibold text-gray-900">Easy Creation</h3>
                    <p class="mt-0.5 text-xs text-gray-500 leading-relaxed">Create events in seconds with image upload and smart tagging</p>
                </div>
            </div>
            <div class="flex items-start gap-3">
                <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-primary-50 flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" />
                    </svg>
                </div>
                <div>
                    <h3 class="text-sm font-semibold text-gray-900">AI-Powered</h3>
                    <p class="mt-0.5 text-xs text-gray-500 leading-relaxed">Smart recommendations and AI-generated content coming soon</p>
                </div>
            </div>
            <div class="flex items-start gap-3">
                <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-primary-50 flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 7.5h-.75A2.25 2.25 0 004.5 9.75v7.5a2.25 2.25 0 002.25 2.25h7.5a2.25 2.25 0 002.25-2.25v-7.5a2.25 2.25 0 00-2.25-2.25h-.75m0-3l-3-3m0 0l-3 3m3-3v11.25m6-2.25h.75a2.25 2.25 0 012.25 2.25v7.5a2.25 2.25 0 01-2.25 2.25h-7.5a2.25 2.25 0 01-2.25-2.25v-7.5a2.25 2.25 0 012.25-2.25H12" />
                    </svg>
                </div>
                <div>
                    <h3 class="text-sm font-semibold text-gray-900">Open Source</h3>
                    <p class="mt-0.5 text-xs text-gray-500 leading-relaxed">Built with .NET 10, Blazor SSR, and Tailwind CSS v4</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Events Section -->
<section id="events" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="flex items-end justify-between mb-10">
        <div>
            <h2 class="text-2xl font-bold text-gray-900">Upcoming Events</h2>
            <p class="mt-1 text-sm text-gray-500">Explore what's happening next</p>
        </div>
        @if (events.Count > 0)
        {
            <a href="/events/create"
               class="hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-primary-600 hover:text-primary-700 transition-colors duration-200">
                View all
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
            </a>
        }
    </div>

    @if (events.Count == 0)
    {
        <div class="text-center py-20 animate-scale-in">
            <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-primary-100 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
            </div>
            <h3 class="text-lg font-medium text-gray-900">No events yet</h3>
            <p class="mt-1 text-gray-500">Get started by creating your first event.</p>
            <a href="/events/create"
               class="inline-flex items-center gap-1.5 mt-6 bg-primary-600 text-white hover:bg-primary-700 px-5 py-2.5 rounded-lg text-sm font-medium transition-all duration-200 hover:shadow-md">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
                </svg>
                Create Event
            </a>
        </div>
    }
    else
    {
        <!-- Featured event (first/most recent) -->
        var featured = events[0];
        <a href="@($"/events/{featured.Id}")"
           class="group block mb-10 bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden transition-all duration-300 hover:shadow-xl hover:-translate-y-1 animate-fade-in">
            <div class="grid grid-cols-1 lg:grid-cols-2">
                <div class="aspect-[16/9] lg:aspect-auto lg:min-h-[320px] bg-gradient-to-br from-primary-100 to-primary-200 overflow-hidden">
                    @if (!string.IsNullOrEmpty(featured.CoverImageUrl))
                    {
                        <img src="@featured.CoverImageUrl" alt="@featured.Title"
                             class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
                    }
                    else
                    {
                        <div class="w-full h-full flex items-center justify-center">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-primary-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                            </svg>
                        </div>
                    }
                </div>
                <div class="p-8 lg:p-10 flex flex-col justify-center">
                    <div class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-primary-50 text-primary-700 text-xs font-medium w-fit mb-4">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M5 2a1 1 0 011 1v1h1a1 1 0 010 2H6v1a1 1 0 01-2 0V6H3a1 1 0 010-2h1V3a1 1 0 011-1zm0 10a1 1 0 011 1v1h1a1 1 0 110 2H6v1a1 1 0 11-2 0v-1H3a1 1 0 110-2h1v-1a1 1 0 011-1zM12 2a1 1 0 01.967.744L14.146 7.2 17.5 9.134a1 1 0 010 1.732l-3.354 1.935-1.18 4.455a1 1 0 01-1.933 0L9.854 12.8 6.5 10.866a1 1 0 010-1.732l3.354-1.935 1.18-4.455A1 1 0 0112 2z" clip-rule="evenodd" />
                        </svg>
                        Featured
                    </div>
                    <h3 class="text-2xl lg:text-3xl font-bold text-gray-900 group-hover:text-primary-600 transition-colors duration-200">
                        @featured.Title
                    </h3>
                    <div class="flex flex-wrap items-center gap-4 mt-4 text-sm text-gray-500">
                        <span class="inline-flex items-center gap-1.5">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                            </svg>
                            @featured.Date.ToString("MMMM dd, yyyy")
                        </span>
                        <span class="inline-flex items-center gap-1.5">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                            @featured.Location
                        </span>
                    </div>
                    <p class="mt-4 text-gray-500 leading-relaxed line-clamp-3">@featured.Description</p>
                    @if (featured.Tags is { Count: > 0 })
                    {
                        <div class="flex flex-wrap gap-2 mt-5">
                            @foreach (var tag in featured.Tags)
                            {
                                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-600">
                                    @tag.Name
                                </span>
                            }
                        </div>
                    }
                </div>
            </div>
        </a>

        <!-- Event grid (rest) -->
        @if (events.Count > 1)
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                @foreach (var (evt, index) in events.Skip(1).Select((e, i) => (e, i)))
                {
                    <a href="@($"/events/{evt.Id}")"
                       class="group block bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden transition-all duration-300 hover:shadow-lg hover:-translate-y-1 animate-slide-up"
                       style="animation-delay: @(index * 80)ms">
                        <div class="aspect-[16/9] bg-gradient-to-br from-primary-100 to-primary-200 overflow-hidden relative">
                            @if (!string.IsNullOrEmpty(evt.CoverImageUrl))
                            {
                                <img src="@evt.CoverImageUrl" alt="@evt.Title"
                                     class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
                            }
                            else
                            {
                                <div class="w-full h-full flex items-center justify-center">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-primary-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                    </svg>
                                </div>
                            }
                            <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                        </div>
                        <div class="p-5">
                            <div class="flex items-center gap-2 text-xs text-gray-500 mb-2">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                </svg>
                                @evt.Date.ToString("MMM dd, yyyy")
                                <span class="text-gray-300">|</span>
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                                </svg>
                                @evt.Location
                            </div>
                            <h3 class="text-lg font-semibold text-gray-900 group-hover:text-primary-600 transition-colors duration-200 line-clamp-1">
                                @evt.Title
                            </h3>
                            <p class="mt-1.5 text-sm text-gray-500 line-clamp-2">@evt.Description</p>
                            @if (evt.Tags is { Count: > 0 })
                            {
                                <div class="flex flex-wrap gap-1.5 mt-3">
                                    @foreach (var tag in evt.Tags.Take(3))
                                    {
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-primary-50 text-primary-700">
                                            @tag.Name
                                        </span>
                                    }
                                    @if (evt.Tags.Count > 3)
                                    {
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500">
                                            +@(evt.Tags.Count - 3)
                                        </span>
                                    }
                                </div>
                            }
                        </div>
                    </a>
                }
            </div>
        }
    }
</section>

@code {
    private List<Event> events = [];
    private int totalTags;
    private int upcomingCount;

    protected override async Task OnInitializedAsync()
    {
        events = await EventService.GetAllAsync();
        totalTags = await EventService.GetTagCountAsync();
        upcomingCount = events.Count(e => e.Date >= DateTime.Today);
    }
}
