@page "/events/{Id:int}/edit"
@using app.Models
@using app.Services
@inject IEventService EventService
@inject IFileUploadService FileUploadService
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Edit Event - Evently</PageTitle>

@if (model is null)
{
    <div class="text-center py-20 animate-fade-in">
        <h2 class="text-xl font-semibold text-gray-900">Event not found</h2>
        <a href="/" class="mt-4 inline-block text-primary-600 hover:text-primary-700 text-sm font-medium">
            Back to events
        </a>
    </div>
}
else
{
    <div class="animate-fade-in">
        <a href="@($"/events/{Id}")" class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-primary-600 transition-colors duration-200 mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
            Back to event
        </a>

        <div class="max-w-2xl mx-auto">
            <h1 class="text-2xl font-bold text-gray-900 mb-6">Edit Event</h1>

            <EditForm Model="model" OnValidSubmit="HandleSubmit" FormName="edit-event" class="space-y-5">
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 space-y-5 animate-slide-up">

                    <div>
                        <label for="title" class="block text-sm font-medium text-gray-700 mb-1.5">Title</label>
                        <InputText id="title" @bind-Value="model.Title"
                                   class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all duration-200"
                                   placeholder="Give your event a name" />
                    </div>

                    <div>
                        <label for="description" class="block text-sm font-medium text-gray-700 mb-1.5">Description</label>
                        <InputTextArea id="description" @bind-Value="model.Description" rows="4"
                                       class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all duration-200 resize-none"
                                       placeholder="What's this event about?" />
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                        <div>
                            <label for="date" class="block text-sm font-medium text-gray-700 mb-1.5">Date</label>
                            <InputDate id="date" @bind-Value="model.Date"
                                       class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all duration-200" />
                        </div>
                        <div>
                            <label for="location" class="block text-sm font-medium text-gray-700 mb-1.5">Location</label>
                            <InputText id="location" @bind-Value="model.Location"
                                       class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all duration-200"
                                       placeholder="Where is it happening?" />
                        </div>
                    </div>

                    <app.Components.Shared.TagSelector SelectedTags="selectedTags" SelectedTagsChanged="tags => selectedTags = tags" AvailableTags="availableTags" />

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1.5">Cover Image</label>
                        <div class="relative">
                            @if (!string.IsNullOrEmpty(coverImageUrl))
                            {
                                <div class="relative rounded-lg overflow-hidden mb-3 animate-scale-in">
                                    <img src="@coverImageUrl" alt="Cover preview" class="w-full aspect-[16/9] object-cover" />
                                    <button type="button" @onclick="RemoveCoverImage"
                                            class="absolute top-2 right-2 p-1.5 bg-black/50 hover:bg-black/70 rounded-full text-white transition-colors duration-200">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                                            <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                                        </svg>
                                    </button>
                                </div>
                            }
                            else
                            {
                                <label class="flex flex-col items-center justify-center w-full h-32 border-2 border-dashed border-gray-300 rounded-lg cursor-pointer hover:border-primary-400 hover:bg-primary-50/50 transition-all duration-200">
                                    <div class="flex flex-col items-center justify-center py-4">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-gray-400 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                        </svg>
                                        <p class="text-sm text-gray-500">
                                            @if (isUploading)
                                            {
                                                <span class="text-primary-600">Uploading...</span>
                                            }
                                            else
                                            {
                                                <span>Click to upload a cover image</span>
                                            }
                                        </p>
                                    </div>
                                    <InputFile OnChange="HandleFileUpload" accept="image/*" class="hidden" />
                                </label>
                            }
                        </div>
                    </div>
                </div>

                <div class="flex items-center justify-end gap-3 pt-2">
                    <a href="@($"/events/{Id}")"
                       class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-all duration-200">
                        Cancel
                    </a>
                    <button type="submit" disabled="@isSubmitting"
                            class="inline-flex items-center gap-1.5 px-5 py-2 text-sm font-medium text-white bg-primary-600 rounded-lg hover:bg-primary-700 transition-all duration-200 hover:shadow-md disabled:opacity-50 disabled:cursor-not-allowed">
                        @if (isSubmitting)
                        {
                            <svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                            </svg>
                        }
                        Save Changes
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Event? model;
    private List<string> selectedTags = [];
    private List<string> availableTags = [];
    private string? coverImageUrl;
    private bool isUploading;
    private bool isSubmitting;

    protected override async Task OnInitializedAsync()
    {
        model = await EventService.GetByIdAsync(Id);
        if (model is not null)
        {
            selectedTags = model.Tags.Select(t => t.Name).ToList();
            coverImageUrl = model.CoverImageUrl;
        }

        availableTags = await EventService.GetAllTagNamesAsync();
    }

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        isUploading = true;
        StateHasChanged();

        try
        {
            var file = e.File;
            await using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            coverImageUrl = await FileUploadService.UploadAsync(stream, file.Name);
        }
        finally
        {
            isUploading = false;
        }
    }

    private void RemoveCoverImage()
    {
        coverImageUrl = null;
    }

    private async Task HandleSubmit()
    {
        if (model is null) return;

        isSubmitting = true;

        model.CoverImageUrl = coverImageUrl;
        await EventService.UpdateAsync(model, selectedTags);

        Nav.NavigateTo($"/events/{Id}", forceLoad: true);
    }
}
